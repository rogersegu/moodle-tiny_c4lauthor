{{!
    @template tiny_c4lauthor/ai_suggest

    AI suggest view rendered inside the existing C4L Author modal.

    Classes prefixed with c4lauthor-ai- to avoid collision with tiny_c4lai.

    Example context (json):
    { "loading": true, "blocks": [], "buttonDelay": 0 }

    @copyright  2026 Roger Segú <rogersegu@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="tiny_c4lauthor__ai">
    {{^loading}}
        {{#warnings.length}}
            <div class="alert alert-success d-flex align-items-center mb-0 border-0 rounded-0">
                {{#pix}}circle-check, tiny_c4lauthor{{/pix}}
                <div class="flex-grow-1">
                    {{#warnings}}<div>{{.}}</div>{{/warnings}}
                </div>
                {{#showReanalyse}}
                    <button class="btn btn-sm btn-outline-success ml-3" data-action="ai-reanalyse">
                        {{reanalyseLabel}}
                    </button>
                {{/showReanalyse}}
            </div>
        {{/warnings.length}}
    {{/loading}}

    <div class="c4lauthor-ai-docview c4lauthor-ai-pad">
        <div class="c4lauthor-ai-docview__inner">
        {{#loading}}
            <div class="py-2 text-muted small c4lauthor-ai-loader-text">
                <div class="c4lauthor-ai-loader-dots" aria-label="{{#str}}ai_analysing, tiny_c4lauthor{{/str}}">
                    <span></span><span></span><span></span>
                </div>
                {{#str}}ai_analysing, tiny_c4lauthor{{/str}}
            </div>
            <div class="c4lauthor-ai-skeleton__heading" style="width:45%">&nbsp;</div>
            <div class="c4lauthor-ai-skeleton__group">
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line" style="width:75%"></div>
            </div>
            <div class="c4lauthor-ai-skeleton__group">
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line" style="width:75%"></div>
            </div>
            <div class="c4lauthor-ai-skeleton__group">
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line" style="width:75%"></div>
            </div>
            <div class="c4lauthor-ai-skeleton__group">
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line" style="width:75%"></div>
            </div>
            <div class="c4lauthor-ai-skeleton__group">
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line"></div>
                <div class="c4lauthor-ai-skeleton__line" style="width:75%"></div>
            </div>
        {{/loading}}

        {{#blocks}}
            {{^loading}}
                {{#isHeading}}<div class="mt-3 c4lauthor-ai-heading c4lauthor-ai-heading--{{type}} c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">{{text}}</div>{{/isHeading}}

                {{#isLI}}
                    {{^isGrouped}}
                    <div class="ms-3 c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">• {{text}}</div>
                    {{/isGrouped}}
                {{/isLI}}

                {{#isMath}}
                    {{^isGrouped}}
                    <div class="ms-3 text-muted small c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms"><code>{{text}}</code></div>
                    {{/isGrouped}}
                {{/isMath}}

                {{#isP}}
                    {{#suggestion}}
                        <label class="c4lauthor-ai-card {{#selected}}c4lauthor-ai-card--selected{{/selected}} c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">
                            <input type="checkbox" class="c4lauthor-ai-card__check" data-action="toggle" data-idx="{{_idx}}" {{#selected}}checked{{/selected}}>
                            <span class="c4lauthor-ai-card__icon">
                                {{#pix}}fi_check, tiny_c4lauthor{{/pix}}
                            </span>
                            <span class="c4lauthor-ai-card__redo-label">{{#pix}}u_redo, tiny_c4lauthor{{/pix}} {{#str}}ai_redo, tiny_c4lauthor{{/str}} {{componentLabel}}</span>
                            <div class="c4lauthor-ai-card__body">
                                <div class="c4lauthor-ai-card__preview">
                                {{#isLearningOutcomes}}
                                    <div class="{{componentClass}}">
                                        <h6 class="c4l-learningoutcomes-title">{{#str}}ai_learning_outcomes_title, tiny_c4lauthor{{/str}}</h6>
                                        <ul class="c4l-learningoutcomes-list"><li>{{text}}</li></ul>
                                    </div>
                                {{/isLearningOutcomes}}
                                {{^isLearningOutcomes}}
                                    <div class="{{componentClass}}">
                                        <p>{{text}}</p>
                                        {{#hasListItems}}<ul>{{#listItems}}<li>{{text}}</li>{{/listItems}}</ul>{{/hasListItems}}
                                        {{#hasFollowingHtml}}{{{followingHtml}}}{{/hasFollowingHtml}}
                                        {{^hasFollowingHtml}}{{#hasFollowingText}}<p>{{followingText}}</p>{{/hasFollowingText}}{{/hasFollowingHtml}}
                                    </div>
                                {{/isLearningOutcomes}}
                                </div>
                                <div class="c4lauthor-ai-card__plain" style="display:none">
                                    <p>{{text}}</p>
                                    {{#hasListItems}}<ul>{{#listItems}}<li>{{text}}</li>{{/listItems}}</ul>{{/hasListItems}}
                                    {{#hasFollowingText}}<p>{{followingText}}</p>{{/hasFollowingText}}
                                </div>
                            </div>
                        </label>
                    {{/suggestion}}

                    {{^suggestion}}
                        {{^isGrouped}}
                        <p class="mt-2 mb-2 c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">{{text}}</p>
                        {{/isGrouped}}
                    {{/suggestion}}
                {{/isP}}

                {{#isC4L}}
                    {{#suggestion}}
                        <label class="c4lauthor-ai-card {{#selected}}c4lauthor-ai-card--selected{{/selected}} c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">
                            <input type="checkbox" class="c4lauthor-ai-card__check" data-action="toggle"
                                   data-idx="{{_idx}}" data-existing="1" {{#selected}}checked{{/selected}}>
                            <span class="c4lauthor-ai-card__icon">
                                {{#pix}}fi_check, tiny_c4lauthor{{/pix}}
                            </span>
                            <span class="c4lauthor-ai-card__redo-label">{{#pix}}u_redo, tiny_c4lauthor{{/pix}} {{#str}}ai_redo, tiny_c4lauthor{{/str}} {{componentLabel}}</span>
                            <div class="c4lauthor-ai-card__body">
                                <div class="c4lauthor-ai-card__preview">
                                {{#isLearningOutcomes}}
                                    <div class="{{componentClass}}">
                                        <h6 class="c4l-learningoutcomes-title">{{#str}}ai_learning_outcomes_title, tiny_c4lauthor{{/str}}</h6>
                                        <ul class="c4l-learningoutcomes-list"><li>{{text}}</li></ul>
                                    </div>
                                {{/isLearningOutcomes}}
                                {{^isLearningOutcomes}}
                                    <div class="{{componentClass}}"><p>{{text}}</p></div>
                                {{/isLearningOutcomes}}
                                </div>
                                <p class="c4lauthor-ai-card__plain" style="display:none">{{text}}</p>
                            </div>
                        </label>
                    {{/suggestion}}
                    {{^suggestion}}
                        {{#isDisplayOnly}}
                        <div class="c4lauthor-ai-reveal" style="animation-delay:{{animDelay}}ms">
                            {{#hasInlineGroup}}
                            <div class="c4l-inline-group">{{{c4lHtml}}}</div>
                            {{/hasInlineGroup}}
                            {{^hasInlineGroup}}
                            <div class="{{componentClass}}">{{{c4lHtml}}}</div>
                            {{/hasInlineGroup}}
                        </div>
                        {{/isDisplayOnly}}
                    {{/suggestion}}
                {{/isC4L}}
            {{/loading}}

        {{/blocks}}
        </div>
    </div>

    {{^loading}}
        <div class="c4lauthor-ai-footer c4lauthor-ai-reveal" {{#buttonDelay}}style="animation-delay:{{buttonDelay}}ms"{{/buttonDelay}}>
            <span class="c4lauthor-ai-footer__count" data-region="selected-count">{{selectedCount}} {{#str}}ai_selected_count, tiny_c4lauthor{{/str}}</span>
            <div class="c4lauthor-ai-footer__actions">
                <button class="btn btn-outline-secondary" data-action="ai-back">
                    {{#str}}ai_back, tiny_c4lauthor{{/str}}
                </button>
                <button class="btn btn-primary" data-action="ai-apply">
                    {{#str}}ai_apply_selected, tiny_c4lauthor{{/str}}
                </button>
            </div>
        </div>
    {{/loading}}
</div>
